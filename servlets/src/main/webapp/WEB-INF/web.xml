<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <servlet>
    <servlet-name>ImportarDatosServlet</servlet-name>
    <servlet-class>com.politecnicomalaga.tienda.view.ImportarDatosServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ImportarDatosServlet</servlet-name>
    <url-pattern>/importar</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ListarProductosServlet</servlet-name>
    <servlet-class>com.politecnicomalaga.tienda.view.ListarProductosServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ListarProductosServlet</servlet-name>
    <url-pattern>/listarProductos</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>BuscarProductoxCodeServlet</servlet-name>
    <servlet-class>com.politecnicomalaga.tienda.view.BuscarProductoxCodeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BuscarProductoxCodeServlet</servlet-name>
    <url-pattern>/buscarProducto</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>BuscarClientexDniServlet</servlet-name>
    <servlet-class>com.politecnicomalaga.tienda.view.BuscarClientexDniServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BuscarClientexDniServlet</servlet-name>
    <url-pattern>/buscarCliente</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ListarProductosxPedidos</servlet-name>
    <servlet-class>com.politecnicomalaga.tienda.view.ListarProductosxPedidos</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ListarProductosxPedidos</servlet-name>
    <url-pattern>/buscarProductoxPedido</url-pattern>
  </servlet-mapping>



</web-app>